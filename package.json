{
  "name": "aplica-ds-docs",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:site": "pnpm --filter @aplica-ds/site dev",
    "dev:docs": "pnpm --filter @aplica-ds/docs start",
    "build:site": "pnpm --filter @aplica-ds/site build",
    "build:docs": "pnpm --filter @aplica-ds/docs build",
    "build": "pnpm build:site && pnpm build:docs"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.12.3+sha512.467df2c586056165580ad6dfb54ceaad94c5a30f80893ebdec5a44c5aa73c205ae4a5bb9d5ed6bb84ea7c249ece786642bbb49d06a307df218d03da41c317417"
}
