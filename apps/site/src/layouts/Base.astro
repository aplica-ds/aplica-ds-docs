---
interface Props {
  title: string;
  description?: string;
  lang?: string;
  image?: string;
  altHref?: string;
  jsonLd?: object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Design tokens que escalam com o produto. Sistema de tokens semântico com arquitetura de 5 camadas, geração dinâmica de temas e suporte multi-plataforma.',
  lang = 'pt-BR',
  image = 'https://aplica.me/og-image.png',
  altHref,
  jsonLd = [],
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://aplica.me').href;
const ogTitle = `${title} — Aplica DS`;
const ogLocale = lang === 'pt-BR' ? 'pt_BR' : 'en_US';
const altLang = lang === 'pt-BR' ? 'en' : 'pt-BR';

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Aplica DS',
  url: 'https://aplica.me',
  logo: 'https://aplica.me/favicon.svg',
  description: 'Open-source design token system with a semantic 5-layer architecture and CLI-driven theme engine.',
  sameAs: [
    'https://github.com/aplica-ds',
    'https://www.npmjs.com/package/@aplica/aplica-theme-engine',
  ],
};

const allJsonLd = [organizationLd, ...jsonLd];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title} — Aplica DS</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang (i18n) -->
    {altHref && (
      <>
        <link rel="alternate" hreflang={altLang} href={altHref} />
        <link rel="alternate" hreflang={lang} href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={lang === 'pt-BR' ? canonicalURL : altHref} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Aplica DS" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- JSON-LD -->
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <!-- Dark mode: apply class before first paint to avoid flash -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('aplica-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          // Explicitly mark light so :root:not(.light) and html:not(.light) selectors behave correctly
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <!-- Aplica DS — all theme token CSS loaded statically so var() chains resolve before any JS island -->
    <link rel="stylesheet" href="/aplica-package/dist/css/foundation/engine/foundation.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/foundation/engine/typography.css" />
    <!-- 16 theme files (4 brands × 2 modes × 2 surfaces) -->
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_tangerine-light-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_tangerine-light-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_tangerine-dark-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_tangerine-dark-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_joy-light-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_joy-light-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_joy-dark-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_joy-dark-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_grinch-light-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_grinch-light-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_grinch-dark-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_grinch-dark-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_blue_sky-light-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_blue_sky-light-negative.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_blue_sky-dark-positive.css" />
    <link rel="stylesheet" href="/aplica-package/dist/css/aplica_blue_sky-dark-negative.css" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VVFNS1CWQK" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VVFNS1CWQK');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* Surfaces */
        --color-bg:              #ffffff;
        --color-bg-subtle:       #f9fafb;
        --color-bg-card:         #ffffff;
        --color-border:          #e5e7eb;

        /* Text */
        --color-text:            #111827;
        --color-text-muted:      #6b7280;

        /* Accent — warm orange-to-pink gradient system */
        --color-accent:          #f97316;
        --color-accent-dark:     #ea580c;
        --color-accent-end:      #ec4899;
        --color-accent-bg:       #fff7ed;
        --color-accent-text:     #c2410c;

        /* Gradients */
        --gradient-primary:      linear-gradient(135deg, #f97316 0%, #ec4899 100%);
        --gradient-hero-overlay: linear-gradient(135deg, rgba(249,115,22,0.06) 0%, rgba(236,72,153,0.04) 50%, rgba(168,85,247,0.06) 100%);

        /* Typography */
        --font-sans:    'Inter', system-ui, sans-serif;
        --font-display: 'DM Sans', system-ui, sans-serif;
        --font-mono:    'JetBrains Mono', monospace;

        /* Layout */
        --max-width:    1200px;
        --radius:       0.625rem;
        --radius-sm:    0.375rem;
        --radius-lg:    1rem;
        --radius-full:  9999px;

        /* Shadows */
        --shadow-sm:    0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md:    0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -1px rgba(0,0,0,0.04);
        --shadow-lg:    0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04);
      }

      html { font-family: var(--font-sans); color: var(--color-text); background: var(--color-bg); }
      body { min-height: 100vh; line-height: 1.6; }

      a { color: var(--color-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      code, pre { font-family: var(--font-mono); }
      pre { background: #1e1e2e; color: #cdd6f4; padding: 1rem 1.25rem; border-radius: var(--radius); overflow-x: auto; font-size: 0.875rem; line-height: 1.7; }

      .container { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }

      /* ── Buttons ─────────────────────────────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border-radius: var(--radius);
        font-weight: 600;
        font-size: 0.9375rem;
        cursor: pointer;
        transition: opacity 0.15s, box-shadow 0.15s, transform 0.1s;
        border: none;
        text-decoration: none;
        white-space: nowrap;
      }
      .btn:hover { text-decoration: none; }
      .btn:active { transform: scale(0.98); }

      .btn-primary {
        background: var(--gradient-primary);
        color: #fff;
        box-shadow: 0 2px 8px rgba(249,115,22,0.3);
      }
      .btn-primary:hover { opacity: 0.9; box-shadow: 0 4px 12px rgba(249,115,22,0.4); }

      .btn-outline {
        background: transparent;
        color: var(--color-text);
        border: 1.5px solid var(--color-border);
      }
      .btn-outline:hover { border-color: var(--color-accent); color: var(--color-accent); background: var(--color-accent-bg); }

      /* ── Cards (used by React islands) ───────────────────────────── */
      .card {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
      }
      .card-interactive {
        cursor: pointer;
        transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s;
      }
      .card-interactive:hover { box-shadow: var(--shadow-md); border-color: #d1d5db; }
      .card-active {
        border-color: var(--color-accent) !important;
        box-shadow: 0 0 0 2px rgba(249,115,22,0.15), var(--shadow-md) !important;
        transform: scale(1.02);
      }

      /* ── Badge ───────────────────────────────────────────────────── */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: var(--color-accent-bg);
        color: var(--color-accent-text);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      /* ── Gradient text ───────────────────────────────────────────── */
      .text-gradient {
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ── Section spacing helper ──────────────────────────────────── */
      .section { padding: 5rem 0; }
      .section-subtle { padding: 5rem 0; background: var(--color-bg-subtle); }

      /* ── Interactive island wrappers ─────────────────────────────── */
      .island-section { padding: 5rem 0; }
      .island-section-subtle { padding: 5rem 0; background: var(--color-bg-subtle); }

      /* ── Code block inside cards ─────────────────────────────────── */
      .code-block {
        background: var(--color-bg-subtle);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        padding: 0.875rem 1rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        overflow-x: auto;
      }

      /* Dark mode — via system preference OR html.dark class (set by toggle) */
      @media (prefers-color-scheme: dark) {
        :root:not(.light) {
          --color-bg:         #0f172a;
          --color-bg-subtle:  #1e293b;
          --color-bg-card:    #1e293b;
          --color-border:     #334155;
          --color-text:       #f1f5f9;
          --color-text-muted: #94a3b8;
          --color-accent:     #fb923c;
          --color-accent-dark:#f97316;
          --color-accent-bg:  rgba(249,115,22,0.12);
          --color-accent-text:#fb923c;
        }
        :root:not(.light) .card-interactive:hover { border-color: #475569; }
        :root:not(.light) .btn-outline:hover { background: rgba(249,115,22,0.1); }
        :root:not(.light) .code-block { background: #0f172a; border-color: #334155; }
      }
      html.dark {
        --color-bg:         #0f172a;
        --color-bg-subtle:  #1e293b;
        --color-bg-card:    #1e293b;
        --color-border:     #334155;
        --color-text:       #f1f5f9;
        --color-text-muted: #94a3b8;
        --color-accent:     #fb923c;
        --color-accent-dark:#f97316;
        --color-accent-bg:  rgba(249,115,22,0.12);
        --color-accent-text:#fb923c;
      }
      html.dark .card-interactive:hover { border-color: #475569; }
      html.dark .btn-outline:hover { background: rgba(249,115,22,0.1); }
      html.dark .code-block { background: #0f172a; border-color: #334155; }

      /* ── Scroll animations ───────────────────────────────────────── */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      [data-animate] {
        opacity: 0;
        transform: translateY(24px);
      }
      [data-animate].is-visible {
        animation: fadeInUp 0.55s cubic-bezier(0.16,1,0.3,1) forwards;
      }
      [data-animate="delay-1"].is-visible { animation-delay: 0.08s; }
      [data-animate="delay-2"].is-visible { animation-delay: 0.16s; }
      [data-animate="delay-3"].is-visible { animation-delay: 0.24s; }
      [data-animate="delay-4"].is-visible { animation-delay: 0.32s; }
      [data-animate="delay-5"].is-visible { animation-delay: 0.40s; }
      [data-animate="delay-6"].is-visible { animation-delay: 0.48s; }

      /* Hover micro-interactions */
      .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
      }

      @media (prefers-reduced-motion: reduce) {
        [data-animate] { opacity: 1; transform: none; }
        [data-animate].is-visible { animation: none; }
        .hover-lift:hover { transform: none; }
      }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function() {
        var obs = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        function initAnimations() {
          document.querySelectorAll('[data-animate]').forEach(function(el) {
            obs.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initAnimations);
        } else {
          initAnimations();
        }
      })();
    </script>
  </body>
</html>
