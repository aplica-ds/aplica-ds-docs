---
interface Props {
  lang?: 'pt-br' | 'en';
}
const { lang = 'pt-br' } = Astro.props;

const ft = {
  'pt-br': {
    tagline:   'Design tokens que escalam com o produto. Arquitetura de 5 camadas, open source, licença MIT.',
    docsCol:   'Documentação',
    overview:  'Visão geral',
    overviewHref: 'https://docs.aplica.design',
    n1:        'Tutoriais N1',
    n1Href:    'https://docs.aplica.design/tutorials/n1-product-designer/N1-01',
    engine:    'Theme Engine',
    engineHref:'https://docs.aplica.design/theme-engine/what-is-theme-engine',
    projCol:   'Projeto',
    about:     'Sobre',
    aboutHref: '/sobre',
    changelog: 'Changelog',
    changelogHref: '/changelog',
    license:   `© ${new Date().getFullYear()} Aplica DS — Licença MIT`,
  },
  en: {
    tagline:   'Design tokens that scale with your product. 5-layer architecture, open source, MIT license.',
    docsCol:   'Documentation',
    overview:  'Overview',
    overviewHref: 'https://docs.aplica.design/en-US',
    n1:        'N1 Tutorials',
    n1Href:    'https://docs.aplica.design/en-US/tutorials/n1-product-designer/N1-01',
    engine:    'Theme Engine',
    engineHref:'https://docs.aplica.design/en-US/theme-engine/what-is-theme-engine',
    projCol:   'Project',
    about:     'About',
    aboutHref: '/en/about',
    changelog: 'Changelog',
    changelogHref: '/en/changelog',
    license:   `© ${new Date().getFullYear()} Aplica DS — MIT License`,
  },
}[lang];
---

<footer style="border-top: 1px solid var(--color-border); margin-top: 2rem; padding: 3.5rem 0 2.5rem;">
  <div class="container">
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem;">
      <!-- Brand column -->
      <div>
        <p style="font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; margin-bottom: 0.75rem; background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; display: inline-block;">
          Aplica DS
        </p>
        <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.7; max-width: 280px;">
          {ft.tagline}
        </p>
      </div>

      <!-- Docs column -->
      <div>
        <p style="font-weight: 600; font-size: 0.8125rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted);">{ft.docsCol}</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={ft.overviewHref} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{ft.overview}</a></li>
          <li><a href={ft.n1Href} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{ft.n1}</a></li>
          <li><a href={ft.engineHref} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{ft.engine}</a></li>
        </ul>
      </div>

      <!-- Project column -->
      <div>
        <p style="font-weight: 600; font-size: 0.8125rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted);">{ft.projCol}</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={ft.aboutHref} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{ft.about}</a></li>
          <li><a href={ft.changelogHref} style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{ft.changelog}</a></li>
          <li><a href="https://github.com/bellentani/aplica-design-tokens" style="color: var(--color-text-muted); font-size: 0.875rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">GitHub</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="padding-top: 1.5rem; border-top: 1px solid var(--color-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <p style="color: var(--color-text-muted); font-size: 0.8125rem;">
        {ft.license}
      </p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="https://github.com/bellentani/aplica-design-tokens" style="color: var(--color-text-muted); font-size: 0.8125rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">GitHub</a>
        <a href={ft.overviewHref} style="color: var(--color-text-muted); font-size: 0.8125rem; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">Docs</a>
      </div>
    </div>
  </div>
</footer>

<style>
  @media (max-width: 640px) {
    footer > div > div:first-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>