---
import { DarkModeToggle } from './DarkModeToggle';
import { routes, type Lang } from '../i18n/routes';

interface Props {
  lang?: Lang;
}
const { lang = 'pt-br' } = Astro.props;

const r = routes[lang];

const t = {
  'pt-br': {
    howItWorks: 'Como funciona',
    forWhom:    'Para quem',
    docs:       'Documentação',
    github:     'GitHub',
    langLabel:  'EN',
  },
  en: {
    howItWorks: 'How it works',
    forWhom:    'For whom',
    docs:       'Documentation',
    github:     'GitHub',
    langLabel:  'PT',
  },
}[lang];

const base = lang === 'en' ? '/en' : '';
---

<header style="border-bottom: 1px solid var(--color-border); position: sticky; top: 0; background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 100;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
    <a href={base + '/'} style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
      <span style="font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
        Aplica DS
      </span>
    </a>
    <nav style="display: flex; align-items: center; gap: 1.5rem; font-size: 0.9375rem;">
      <a href={r.comoFunciona} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.howItWorks}</a>
      <a href={r.paraQuem} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.forWhom}</a>
      <a href={r.docs} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.docs}</a>
      <a href="https://github.com/bellentani/aplica-design-tokens" class="btn btn-outline" target="_blank" rel="noopener noreferrer" style="padding: 0.375rem 0.875rem; font-size: 0.875rem; display: inline-flex; align-items: center; gap: 0.375rem;">
        {t.github}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <DarkModeToggle client:load />
      <a href={r.langSwitch} style="color: var(--color-text-muted); font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.05em; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.langLabel}</a>
    </nav>
  </div>
</header>

<style>
  /* System dark preference — only applies when user hasn't explicitly chosen light */
  @media (prefers-color-scheme: dark) {
    html:not(.light) header {
      background: rgba(15, 23, 42, 0.9) !important;
    }
  }
  /* Explicit dark toggle — always applies regardless of system preference */
  html.dark header {
    background: rgba(15, 23, 42, 0.9) !important;
  }
  /* Explicit light toggle — always restores light background */
  html.light header {
    background: rgba(255, 255, 255, 0.9) !important;
  }
</style>