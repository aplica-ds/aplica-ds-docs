---
import { DarkModeToggle } from './DarkModeToggle';

interface Props {
  lang?: 'pt-br' | 'en';
}
const { lang = 'pt-br' } = Astro.props;

const t = {
  'pt-br': {
    howItWorks:     'Como funciona',
    howItWorksHref: '/como-funciona',
    forWhom:        'Para quem',
    forWhomHref:    '/para-quem',
    docs:           'Documentação',
    docsHref:       'https://docs.aplica.me',
    github:         'GitHub',
    langSwitch:     'EN',
    langHref:       '/en',
  },
  en: {
    howItWorks:     'How it works',
    howItWorksHref: '/en/how-it-works',
    forWhom:        'For whom',
    forWhomHref:    '/en/for-whom',
    docs:           'Documentation',
    docsHref:       'https://docs.aplica.me/en-US',
    github:         'GitHub',
    langSwitch:     'PT',
    langHref:       '/',
  },
}[lang];

const base = lang === 'en' ? '/en' : '';
---

<header style="border-bottom: 1px solid var(--color-border); position: sticky; top: 0; background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 100;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
    <a href={base + '/'} style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
      <span style="font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
        Aplica DS
      </span>
    </a>
    <nav style="display: flex; align-items: center; gap: 1.5rem; font-size: 0.9375rem;">
      <a href={t.howItWorksHref} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.howItWorks}</a>
      <a href={t.forWhomHref} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.forWhom}</a>
      <a href={t.docsHref} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.docs}</a>
      <a href="https://github.com/bellentani/aplica-design-tokens" class="btn btn-outline" style="padding: 0.375rem 0.875rem; font-size: 0.875rem;">{t.github}</a>
      <DarkModeToggle client:load />
      <a href={t.langHref} style="color: var(--color-text-muted); font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.05em; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.langSwitch}</a>
    </nav>
  </div>
</header>

<style>
  /* System dark preference — only applies when user hasn't explicitly chosen light */
  @media (prefers-color-scheme: dark) {
    html:not(.light) header {
      background: rgba(15, 23, 42, 0.9) !important;
    }
  }
  /* Explicit dark toggle — always applies regardless of system preference */
  html.dark header {
    background: rgba(15, 23, 42, 0.9) !important;
  }
  /* Explicit light toggle — always restores light background */
  html.light header {
    background: rgba(255, 255, 255, 0.9) !important;
  }
</style>