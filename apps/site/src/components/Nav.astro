---
import { DarkModeToggle } from './DarkModeToggle';
import { routes, type Lang } from '../i18n/routes';

interface Props {
  lang?: Lang;
}
const { lang = 'pt-br' } = Astro.props;

const r = routes[lang];

const t = {
  'pt-br': {
    howItWorks: 'Como funciona',
    forWhom:    'Trilhas de aprendizado',
    useNpm:     'Configurar e usar',
    concepts:   'Entender o sistema',
    npm:        'npm',
    langLabel:  'EN',
  },
  en: {
    howItWorks: 'How it works',
    forWhom:    'Learning tracks',
    useNpm:     'Configure & use',
    concepts:   'Understand',
    npm:        'npm',
    langLabel:  'PT',
  },
}[lang];

const base = lang === 'en' ? '/en' : '';
---

<header id="nav" style="border-bottom: 1px solid var(--color-border); position: sticky; top: 0; background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 100;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
    <!-- Logo -->
    <a href={base + '/'} style="display: flex; align-items: center; text-decoration: none; flex-shrink: 0;">
      <img src="/logo-title-magenta.svg" alt="Aplica DS" height="32" style="display: block;" />
    </a>

    <!-- Desktop nav -->
    <nav id="desktop-nav" style="display: flex; align-items: center; gap: 1.5rem; font-size: 0.9375rem;">
      <a href={r.comoFunciona} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.howItWorks}</a>
      <a href={r.paraQuem} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.forWhom}</a>
      <a href={r.docsNpm} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.useNpm}</a>
      <a href={r.docsConceito} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.concepts}</a>
      <a href="https://www.npmjs.com/package/@aplica/aplica-theme-engine" class="btn btn-outline" target="_blank" rel="noopener noreferrer" style="padding: 0.375rem 0.875rem; font-size: 0.875rem; display: inline-flex; align-items: center; gap: 0.375rem;">
        {t.npm}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <DarkModeToggle client:load />
      <a href={r.langSwitch} style="color: var(--color-text-muted); font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.05em; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-muted)'">{t.langLabel}</a>
    </nav>

    <!-- Mobile controls (hamburger + dark toggle) -->
    <div id="mobile-controls" style="display: none; align-items: center; gap: 0.625rem;">
      <DarkModeToggle client:load />
      <button id="menu-btn" aria-label="Menu" aria-expanded="false" style="display: flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border: 1.5px solid var(--color-border); border-radius: 0.5rem; background: transparent; cursor: pointer; color: var(--color-text-muted); transition: border-color 0.15s, color 0.15s;">
        <svg id="icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" style="display: none; border-top: 1px solid var(--color-border); padding: 1rem 1.5rem 1.25rem; flex-direction: column; gap: 0;">
    <a href={r.comoFunciona} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; font-size: 0.9375rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">{t.howItWorks}</a>
    <a href={r.paraQuem} style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; font-size: 0.9375rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">{t.forWhom}</a>
    <a href={r.docsNpm} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; font-size: 0.9375rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">{t.useNpm} ↗</a>
    <a href={r.docsConceito} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted); text-decoration: none; font-weight: 500; font-size: 0.9375rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">{t.concepts} ↗</a>
    <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 1rem;">
      <a href="https://www.npmjs.com/package/@aplica/aplica-theme-engine" class="btn btn-outline" target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem; padding: 0.5rem 1rem;">{t.npm} ↗</a>
      <a href={r.langSwitch} style="color: var(--color-text-muted); font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.05em; text-decoration: none;">{t.langLabel}</a>
    </div>
  </div>
</header>

<style>
  /* System dark preference */
  @media (prefers-color-scheme: dark) {
    html:not(.light) header { background: rgba(15, 23, 42, 0.9) !important; }
  }
  html.dark header { background: rgba(15, 23, 42, 0.9) !important; }
  html.light header { background: rgba(255, 255, 255, 0.9) !important; }

  /* Mobile: hide desktop nav, show hamburger */
  @media (max-width: 768px) {
    #desktop-nav { display: none !important; }
    #mobile-controls { display: flex !important; }
  }
  #mobile-menu { max-height: calc(100vh - 64px); overflow-y: auto; }
</style>

<script is:inline>
  (function() {
    var btn = document.getElementById('menu-btn');
    var menu = document.getElementById('mobile-menu');
    var iconOpen = document.getElementById('icon-open');
    var iconClose = document.getElementById('icon-close');
    if (!btn || !menu) return;
    btn.addEventListener('click', function() {
      var isOpen = menu.style.display === 'flex';
      menu.style.display = isOpen ? 'none' : 'flex';
      iconOpen.style.display = isOpen ? '' : 'none';
      iconClose.style.display = isOpen ? 'none' : '';
      btn.setAttribute('aria-expanded', (!isOpen).toString());
    });
  })();
</script>