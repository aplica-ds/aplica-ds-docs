---
interface Props {
  lang?: 'pt-br' | 'en';
}
const { lang = 'pt-br' } = Astro.props;

const t = {
  'pt-br': {
    howItWorks: 'Como funciona',
    forWhom:    'Para quem',
    docs:       'Documentação',
    github:     'GitHub',
    langSwitch: 'EN',
    langHref:   '/en',
  },
  en: {
    howItWorks: 'How it works',
    forWhom:    'For whom',
    docs:       'Documentation',
    github:     'GitHub',
    langSwitch: 'PT',
    langHref:   '/',
  },
}[lang];

const base = lang === 'en' ? '/en' : '';
---

<header style="border-bottom: 1px solid var(--color-border); position: sticky; top: 0; background: var(--color-bg); z-index: 100;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 60px;">
    <a href={base + '/'} style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: var(--color-text); text-decoration: none;">
      Aplica DS
    </a>
    <nav style="display: flex; align-items: center; gap: 1.5rem; font-size: 0.9375rem;">
      <a href={base + '/como-funciona'} style="color: var(--color-text-muted);">{t.howItWorks}</a>
      <a href={base + '/para-quem'}    style="color: var(--color-text-muted);">{t.forWhom}</a>
      <a href="https://docs.aplica.design" style="color: var(--color-text-muted);">{t.docs}</a>
      <a href="https://github.com/aplica-ds/aplica-ds" class="btn btn-outline" style="padding: 0.375rem 0.875rem; font-size: 0.875rem;">{t.github}</a>
      <a href={t.langHref} style="color: var(--color-text-muted); font-size: 0.8125rem; font-weight: 600;">{t.langSwitch}</a>
    </nav>
  </div>
</header>
