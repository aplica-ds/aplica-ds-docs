---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { LayerDemo } from '../components/LayerDemo';
import { ThemeGrid } from '../components/ThemeGrid';
import { ThemePlayground } from '../components/ThemePlayground';
---

<Base title="Design tokens que escalam com o produto">
  <Nav lang="pt-br" />

  <!-- ── 1. Hero ─────────────────────────────────────────────────── -->
  <section style="position: relative; overflow: hidden; padding: 6rem 0 4.5rem; text-align: center;">
    <!-- Gradient overlay from v0 visual identity -->
    <div style="position: absolute; inset: 0; background: var(--gradient-hero-overlay); pointer-events: none;" aria-hidden="true"></div>

    <div class="container" style="position: relative;">
      <p class="badge" style="margin-bottom: 1.5rem;">
        Open Source · MIT
      </p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.15; max-width: 760px; margin: 0 auto 1.25rem;">
        Design tokens que
        <span class="text-gradient"> escalam com o produto.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-text-muted); max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7;">
        Arquitetura de 5 camadas, geração dinâmica de temas, dark mode por construção e suporte a Figma, React, Vue, Flutter — a partir de um único arquivo de configuração.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://docs.aplica.me/tutorials/n1-product-designer/N1-01" class="btn btn-primary">
          Começar pelos tutoriais N1 →
        </a>
        <a href="https://github.com/bellentani/aplica-design-tokens" class="btn btn-outline">
          Ver no GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- ── 2. O problema ──────────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">O problema que todo time enfrenta</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 520px; margin: 0 auto 3rem;">Tokens hardcoded, dark mode manual, inconsistências entre plataformas — o custo cresce a cada novo produto ou parceiro.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto;">
        <div class="card" style="padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🔁</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Duplicação</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">O mesmo azul definido em 14 lugares diferentes. Muda um, esquece os outros.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🌙</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Dark mode manual</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Cada cor precisa de uma variante escura escrita à mão. Bugs garantidos.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🏝️</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Silos de plataforma</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Web, mobile e Figma vivem mundos separados. Sincronizar custa horas.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">📈</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Escala impossível</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Cada novo produto ou parceiro multiplica o problema. Não existe "limpar depois".</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3. Arquitetura de 5 camadas — interactive island ───────── -->
  <LayerDemo lang="pt-br" client:load />

  <!-- ── 4. Temas gerados automaticamente — interactive island ──── -->
  <ThemeGrid lang="pt-br" client:load />

  <!-- ── 5. Playground de Temas — token resolution integrada ─────── -->
  <ThemePlayground lang="pt-br" client:load />

  <!-- ── 6. Como funciona ───────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">Como funciona</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 480px; margin: 0 auto 3rem;">De um arquivo de config à tokens prontos para uso em qualquer plataforma.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; max-width: 860px; margin: 0 auto;">
        <div style="background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">01</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Config</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">Defina as cores da marca, tipografia e mapeamentos semânticos em um arquivo .config.mjs.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">export default &#123;
  name: 'minha-marca',
  colors: &#123;
    brand_blue: '#2563EB',
    ...
  &#125;
&#125;</pre>
        </div>
        <div style="background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">02</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Build</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">npm run build:themes executa o pipeline: paleta OKLCh → semântica → Foundation → outputs.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">npm run build:themes

✓ palette decomposed
✓ semantic synced
✓ 4 themes written</pre>
        </div>
        <div style="background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">03</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Uso</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">CSS Custom Properties, ESM, TypeScript declarations e JSON — prontos para web, mobile e Figma.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">.btn &#123;
  background: var(
    --semantic-color-
    interface-function-
    primary-normal-bg);
&#125;</pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 7. Para quem ───────────────────────────────────────────── -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">Para quem é o Aplica DS?</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 480px; margin: 0 auto 3rem;">Três trilhas de aprendizado, cada uma com 6 tutoriais progressivos.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto;">
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #f97316; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; box-shadow: var(--shadow-sm);">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #f97316;">N1</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">Product Designer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Usa o sistema sem precisar entender a arquitetura. Aprende vocabulário de tokens, acessibilidade e dark mode no Figma.</p>
          <a href="https://docs.aplica.me/tutorials/n1-product-designer/N1-01" style="color: #f97316; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N1 →</a>
        </div>
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #8b5cf6; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; box-shadow: var(--shadow-sm);">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #8b5cf6;">N2</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">System Designer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Configura e estende o sistema. Entende o pipeline OKLCh, cria temas, define sobreposições responsáveis.</p>
          <a href="https://docs.aplica.me/08-tutorials/n2-system-designer/01-modelo-mental-5-camadas" style="color: #8b5cf6; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N2 →</a>
        </div>
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #10b981; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; box-shadow: var(--shadow-sm);">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #10b981;">N3</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">Design Engineer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Constrói componentes conformantes, integra tokens em qualquer plataforma e adiciona novas marcas ao engine.</p>
          <a href="https://docs.aplica.me/08-tutorials/n3-design-engineer/01-contrato-de-tokens" style="color: #10b981; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N3 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 8. Open source ─────────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container" style="text-align: center;">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; margin-bottom: 0.75rem;">100% open source</h2>
      <p style="color: var(--color-text-muted); max-width: 480px; margin: 0 auto 2rem; line-height: 1.7;">Licença MIT. Sem vendor lock-in. Contribuições via PR. O git history é a documentação.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/bellentani/aplica-design-tokens" class="btn btn-primary">Ver repositório</a>
        <a href="https://docs.aplica.me" class="btn btn-outline">Ler documentação</a>
      </div>
    </div>
  </section>

  <!-- ── 9. CTA final ───────────────────────────────────────────── -->
  <section style="padding: 5rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Pronto para começar?</h2>
      <p style="color: var(--color-text-muted); max-width: 440px; margin: 0 auto 2.5rem; line-height: 1.7;">
        Os tutoriais N1 introduzem o sistema em 30 minutos. Nenhum setup necessário — só o Figma.
      </p>
      <a href="https://docs.aplica.me/tutorials/n1-product-designer/N1-01" class="btn btn-primary" style="font-size: 1rem; padding: 0.75rem 1.75rem;">
        Começar pelos tutoriais N1 →
      </a>
    </div>
  </section>

  <Footer lang="pt-br" />
</Base>