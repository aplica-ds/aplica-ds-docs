---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Design tokens que escalam com o produto">
  <Nav lang="pt-br" />

  <!-- ── 1. Hero ─────────────────────────────────────────────────── -->
  <section style="padding: 6rem 0 4rem; text-align: center;">
    <div class="container">
      <p style="display: inline-block; background: #eff6ff; color: #1d4ed8; font-size: 0.8125rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 99px; margin-bottom: 1.5rem; letter-spacing: 0.04em; text-transform: uppercase;">
        Open Source · MIT
      </p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.15; max-width: 760px; margin: 0 auto 1.25rem;">
        Design tokens que escalam com o produto.
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-text-muted); max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7;">
        Arquitetura de 5 camadas, geração dinâmica de temas, dark mode por construção e suporte a Figma, React, Vue, Flutter — a partir de um único arquivo de configuração.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://docs.aplica.design/08-tutorials/n1-product-designer/01-o-que-sao-tokens" class="btn btn-primary">
          Começar pelos tutoriais N1 →
        </a>
        <a href="https://github.com/aplica-ds/aplica-ds" class="btn btn-outline">
          Ver no GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- ── 2. O problema ──────────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">O problema que todo time enfrenta</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 520px; margin: 0 auto 3rem;">Tokens hardcoded, dark mode manual, inconsistências entre plataformas — o custo cresce a cada novo produto ou parceiro.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto;">
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🔁</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Duplicação</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">O mesmo azul definido em 14 lugares diferentes. Muda um, esquece os outros.</p>
        </div>
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🌙</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Dark mode manual</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Cada cor precisa de uma variante escura escrita à mão. Bugs garantidos.</p>
        </div>
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">🏝️</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Silos de plataforma</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Web, mobile e Figma vivem mundos separados. Sincronizar custa horas.</p>
        </div>
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem;">
          <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">📈</div>
          <h3 style="font-weight: 600; margin-bottom: 0.5rem;">Escala impossível</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Cada novo produto ou parceiro multiplica o problema. Não existe "limpar depois".</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3. A solução — 5 camadas ───────────────────────────────── -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">Arquitetura de 5 camadas</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 520px; margin: 0 auto 3rem;">Cada camada tem uma responsabilidade única. Trocar uma marca não afeta a semântica. Trocar o modo não afeta a estrutura.</p>
      <div style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 680px; margin: 0 auto;">
        <div style="display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-left: 4px solid #2563eb; border-radius: var(--radius);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: #2563eb; min-width: 24px; margin-top: 2px;">01</span>
          <div><strong style="font-size: 0.9375rem;">Brand</strong><p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; line-height: 1.5;">Identidade visual — paleta, tipografia, personalidade da marca.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-left: 4px solid #7c3aed; border-radius: var(--radius);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: #7c3aed; min-width: 24px; margin-top: 2px;">02</span>
          <div><strong style="font-size: 0.9375rem;">Mode</strong><p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; line-height: 1.5;">Light / Dark — inversão perceptual da paleta via OKLCh.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-left: 4px solid #0891b2; border-radius: var(--radius);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: #0891b2; min-width: 24px; margin-top: 2px;">03</span>
          <div><strong style="font-size: 0.9375rem;">Surface</strong><p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; line-height: 1.5;">Positive / Negative — fundo claro ou escuro dentro do mesmo modo.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-left: 4px solid #059669; border-radius: var(--radius);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: #059669; min-width: 24px; margin-top: 2px;">04</span>
          <div><strong style="font-size: 0.9375rem;">Semantic</strong><p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; line-height: 1.5;">Nomes com significado: interface.function.primary, interface.brand.ambient…</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-left: 4px solid #d97706; border-radius: var(--radius);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: #d97706; min-width: 24px; margin-top: 2px;">05</span>
          <div><strong style="font-size: 0.9375rem;">Foundation</strong><p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; line-height: 1.5;">Aliases simples para times de produto: bg.primary, text.body, spacing.medium.</p></div>
        </div>
      </div>
      <p style="text-align: center; color: var(--color-text-muted); font-size: 0.875rem; margin-top: 1.5rem;">
        + camada ortogonal <strong>Dimension</strong> (minor / normal / major) para escala dimensional.
      </p>
    </div>
  </section>

  <!-- ── 4. Como funciona ───────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">Como funciona</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 480px; margin: 0 auto 3rem;">De um arquivo de config à tokens prontos para uso em qualquer plataforma.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; max-width: 860px; margin: 0 auto;">
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden;">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">01</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Config</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">Defina as cores da marca, tipografia e mapeamentos semânticos em um arquivo .config.mjs.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">export default &#123;
  name: 'minha-marca',
  colors: &#123;
    brand_blue: '#2563EB',
    ...
  &#125;
&#125;</pre>
        </div>
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden;">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">02</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Build</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">npm run build:themes executa o pipeline: paleta OKLCh → semântica → Foundation → outputs.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">npm run build:themes

✓ palette decomposed
✓ semantic synced
✓ 4 themes written</pre>
        </div>
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden;">
          <div style="padding: 1.25rem 1.25rem 0;">
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-accent);">03</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin: 0.25rem 0 0.5rem;">Uso</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">CSS Custom Properties, ESM, TypeScript declarations e JSON — prontos para web, mobile e Figma.</p>
          </div>
          <pre style="margin: 0; border-radius: 0; font-size: 0.8125rem;">.btn &#123;
  background: var(
    --semantic-color-
    interface-function-
    primary-normal-bg);
&#125;</pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. Para quem ───────────────────────────────────────────── -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem;">Para quem é o Aplica DS?</h2>
      <p style="text-align: center; color: var(--color-text-muted); max-width: 480px; margin: 0 auto 3rem;">Três trilhas de aprendizado, cada uma com 6 tutoriais progressivos.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto;">
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #2563eb; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #2563eb;">N1</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">Product Designer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Usa o sistema sem precisar entender a arquitetura. Aprende vocabulário de tokens, acessibilidade e dark mode no Figma.</p>
          <a href="https://docs.aplica.design/08-tutorials/n1-product-designer/01-o-que-sao-tokens" style="color: #2563eb; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N1 →</a>
        </div>
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #7c3aed; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #7c3aed;">N2</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">System Designer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Configura e estende o sistema. Entende o pipeline OKLCh, cria temas, define sobreposições responsáveis.</p>
          <a href="https://docs.aplica.design/08-tutorials/n2-system-designer/01-modelo-mental-5-camadas" style="color: #7c3aed; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N2 →</a>
        </div>
        <div style="border: 1px solid var(--color-border); border-top: 3px solid #059669; border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #059669;">N3</span>
            <h3 style="font-weight: 700; font-size: 1.0625rem; margin-top: 0.25rem;">Design Engineer</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6; flex: 1;">Constrói componentes conformantes, integra tokens em qualquer plataforma e adiciona novas marcas ao engine.</p>
          <a href="https://docs.aplica.design/08-tutorials/n3-design-engineer/01-contrato-de-tokens" style="color: #059669; font-weight: 600; font-size: 0.9rem;">Começar tutoriais N3 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 6. Open source ─────────────────────────────────────────── -->
  <section style="padding: 5rem 0; background: var(--color-bg-subtle);">
    <div class="container" style="text-align: center;">
      <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; margin-bottom: 0.75rem;">100% open source</h2>
      <p style="color: var(--color-text-muted); max-width: 480px; margin: 0 auto 2rem; line-height: 1.7;">Licença MIT. Sem vendor lock-in. Contribuições via PR. O git history é a documentação.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/aplica-ds/aplica-ds" class="btn btn-primary">Ver repositório</a>
        <a href="https://docs.aplica.design" class="btn btn-outline">Ler documentação</a>
      </div>
    </div>
  </section>

  <!-- ── 7. CTA final ───────────────────────────────────────────── -->
  <section style="padding: 5rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Pronto para começar?</h2>
      <p style="color: var(--color-text-muted); max-width: 440px; margin: 0 auto 2.5rem; line-height: 1.7;">
        Os tutoriais N1 introduzem o sistema em 30 minutos. Nenhum setup necessário — só o Figma.
      </p>
      <a href="https://docs.aplica.design/08-tutorials/n1-product-designer/01-o-que-sao-tokens" class="btn btn-primary" style="font-size: 1rem; padding: 0.75rem 1.75rem;">
        Começar pelos tutoriais N1 →
      </a>
    </div>
  </section>

  <Footer lang="pt-br" />
</Base>
