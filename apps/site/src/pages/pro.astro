  <script is:inline>
    (function() {
      var btn = document.getElementById('btn-calendly');
      var container = document.getElementById('calendly-container');
      if (!btn || !container) return;
      btn.addEventListener('click', function() {
        var isOpen = container.style.display !== 'none';
        container.style.display = isOpen ? 'none' : 'block';
        btn.textContent = isOpen ? '📅 Agendar Conversa' : '✕ Fechar agenda';
        if (!isOpen) {
          container.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      // Smooth scroll for anchor links
      document.querySelectorAll('#pro-nav a[href^="#"], .pro-btn[href^="#"], .pro-btn-outline[href^="#"]').forEach(function(a) {
        a.addEventListener('click', function(e) {
          var href = a.getAttribute('href');
          var target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // Close mobile menu if open
            var menu = document.getElementById('pro-mobile-menu');
            if (menu) menu.style.display = 'none';
          }
        });
      });

      // Mobile hamburger
      var menuBtn = document.getElementById('pro-menu-btn');
      var mobileMenu = document.getElementById('pro-mobile-menu');
      var iconOpen = document.getElementById('pro-icon-open');
      var iconClose = document.getElementById('pro-icon-close');
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', function() {
          var isOpen = mobileMenu.style.display === 'flex';
          mobileMenu.style.display = isOpen ? 'none' : 'flex';
          if (iconOpen) iconOpen.style.display = isOpen ? '' : 'none';
          if (iconClose) iconClose.style.display = isOpen ? 'none' : '';
          menuBtn.setAttribute('aria-expanded', (!isOpen).toString());
        });
      }

      // Nav background on scroll
      var nav = document.getElementById('pro-nav');
      if (nav) {
        window.addEventListener('scroll', function() {
          nav.classList.toggle('scrolled', window.scrollY > 16);
        });
      }
    })();
  </script>

