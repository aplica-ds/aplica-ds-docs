---
import Base from '../../layouts/Base.astro';
import { DarkModeToggle } from '../../components/DarkModeToggle';
---

<Base
  title="Aplica Design Pro — Tokenized Design System Consulting"
  description="Tokenized Design System for your team. A definitive bridge between Figma and code with positive ROI in 4-6 months. Discovery Week: BRL 3,500."
  lang="en"
  altHref="https://aplica.me/pro"
>

  <!-- ── ProNav ──────────────────────────────────────────────────── -->
  <header id="pro-nav">
    <div class="pro-container" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
      <a href="#hero" class="pro-logo">Aplica.Design Pro</a>

      <nav id="pro-desktop-nav">
        <a href="#sumario">Objectives</a>
        <a href="#escopo">Scope</a>
        <a href="#cronograma">Timeline</a>
        <a href="#investimento">Investment</a>
        <a href="#casos-sucesso">Results</a>
        <a href="#proximos-passos">Contact</a>
      </nav>

      <div id="pro-nav-right" style="display: flex; align-items: center; gap: 0.75rem;">
        <a href="/pro" class="pro-lang-toggle">PT</a>
        <DarkModeToggle client:load />
        <button id="pro-menu-btn" aria-label="Menu" aria-expanded="false" class="pro-hamburger">
          <svg id="pro-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="pro-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <div id="pro-mobile-menu">
      <a href="#sumario">Objectives</a>
      <a href="#escopo">Scope</a>
      <a href="#cronograma">Timeline</a>
      <a href="#investimento">Investment</a>
      <a href="#casos-sucesso">Results</a>
      <a href="#proximos-passos">Contact</a>
      <div style="display:flex; justify-content:space-between; align-items:center; padding-top:0.75rem; border-top: 1px solid var(--color-border);">
        <a href="/pro" class="pro-lang-toggle">PT</a>
      </div>
    </div>
  </header>

  <main>

    <!-- ── Hero ───────────────────────────────────────────────────── -->
    <section id="hero" class="pro-section-alt">
      <div class="pro-container">
        <div style="max-width: 900px;">
          <p class="pro-label">Design System Ops · Consulting</p>
          <h1 class="pro-h1">
            Design System<br/>
            <span style="font-weight: 300;">Tokenized</span>
          </h1>
          <p style="font-size: 1.125rem; color: var(--color-text-muted); max-width: 600px; line-height: 1.75; margin-bottom: 2.5rem;">
            Establish a definitive bridge between design and development, eliminating inconsistencies and drastically accelerating digital product delivery.
          </p>
          <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 4rem;">
            <a href="#proximos-passos" class="pro-btn">Start Discovery</a>
            <a href="#sumario" class="pro-btn-outline">View Details</a>
          </div>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 2rem; max-width: 560px; border-top: 2px solid var(--color-text); padding-top: 2rem;">
            <div>
              <div style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1;">70%</div>
              <div style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono); margin-top: 0.25rem;">Time reduction</div>
            </div>
            <div>
              <div style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1;">4-6</div>
              <div style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono); margin-top: 0.25rem;">Months to ROI</div>
            </div>
            <div>
              <div style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1;">95%</div>
              <div style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono); margin-top: 0.25rem;">Consistency</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Objectives ─────────────────────────────────────────────── -->
    <section id="sumario" class="pro-section">
      <div class="pro-container">
        <div style="margin-bottom: 4rem;">
          <h2 class="pro-h2">Objectives</h2>
          <p style="color: var(--color-text-muted); font-size: 1.0625rem; margin-top: 0.75rem;">These are the main objectives of this proposal</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
          <div class="pro-card">
            <p class="pro-label">OBJECTIVE 01</p>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.5rem 0 0.5rem;">Single Source of Truth</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Create definitive connection between Figma and code</p>
          </div>
          <div class="pro-card">
            <p class="pro-label">OBJECTIVE 02</p>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.5rem 0 0.5rem;">70% time reduction</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Drastically accelerate interface implementation</p>
          </div>
          <div class="pro-card">
            <p class="pro-label">OBJECTIVE 03</p>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.5rem 0 0.5rem;">Complete automation</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Automatic propagation of design changes</p>
          </div>
          <div class="pro-card">
            <p class="pro-label">OBJECTIVE 04</p>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.5rem 0 0.5rem;">AI-ready</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Infrastructure for advanced automations</p>
          </div>
        </div>
        <div style="border: 2px solid var(--color-text); padding: 2rem; border-radius: var(--radius); display: flex; gap: 1rem; align-items: flex-start; background: var(--color-bg-subtle);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <p style="font-weight: 700; margin-bottom: 0.375rem;">Expected Result</p>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">Positive ROI in 3-6 months through time savings and rework reduction, with a system prepared to scale indefinitely.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Scope ───────────────────────────────────────────────────── -->
    <section id="escopo" class="pro-section-alt">
      <div class="pro-container">
        <div style="margin-bottom: 4rem;">
          <h2 class="pro-h2">Scope</h2>
          <p style="color: var(--color-text-muted); font-size: 1.0625rem; margin-top: 0.75rem;">Three structured phases to ensure complete implementation</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0;">

          <details class="pro-accordion" open>
            <summary>
              <div>
                <p class="pro-label" style="margin-bottom: 0.375rem;">4-6 WEEKS</p>
                <h3 class="pro-accordion-title">Phase 1: Foundation and Architecture</h3>
              </div>
              <svg class="pro-accordion-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <ul class="pro-deliverables">
              <li>Complete Design Token architecture (primitives, semantics, components)</li>
              <li>Migration of existing styles to structured tokens</li>
              <li>Tokens Studio setup in Figma</li>
              <li>Synchronization with Git repository (GitHub/GitLab)</li>
              <li>Base theme system (light/dark + structure for multiple brands)</li>
              <li>Architecture and decisions documentation</li>
            </ul>
          </details>

          <details class="pro-accordion">
            <summary>
              <div>
                <p class="pro-label" style="margin-bottom: 0.375rem;">3-4 WEEKS</p>
                <h3 class="pro-accordion-title">Phase 2: Development Integration</h3>
              </div>
              <svg class="pro-accordion-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <ul class="pro-deliverables">
              <li>Style Dictionary setup with custom transformers</li>
              <li>Automated build pipeline (CI/CD)</li>
              <li>Token generation for multiple platforms (Web/Mobile)</li>
              <li>Integration with existing codebase</li>
              <li>Example tokenized components</li>
              <li>Automated consistency tests</li>
            </ul>
          </details>

          <details class="pro-accordion">
            <summary>
              <div>
                <p class="pro-label" style="margin-bottom: 0.375rem;">2-3 WEEKS</p>
                <h3 class="pro-accordion-title">Phase 3: Training and Handoff</h3>
              </div>
              <svg class="pro-accordion-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <ul class="pro-deliverables">
              <li>Complete training for design team</li>
              <li>Technical training for developers</li>
              <li>Custom usage documentation</li>
              <li>Maintenance playbooks</li>
              <li>Governance and process setup</li>
              <li>Support for initial implementations</li>
            </ul>
          </details>

        </div>
      </div>
    </section>

    <!-- ── Timeline ────────────────────────────────────────────────── -->
    <section id="cronograma" class="pro-section">
      <div class="pro-container">
        <div style="margin-bottom: 4rem;">
          <h2 class="pro-h2">Timeline</h2>
          <p style="color: var(--color-text-muted); font-size: 1.0625rem; margin-top: 0.75rem;">Estimated timeline of 10 to 13 weeks divided into quarterly stages</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0; max-width: 640px;">
          <div class="pro-milestone">
            <p class="pro-label">Q1</p>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0.25rem 0 0.25rem;">Discovery and Planning</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem;">Complete mapping and architecture definition</p>
          </div>
          <div class="pro-milestone">
            <p class="pro-label">Q2</p>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0.25rem 0 0.25rem;">Foundation and Architecture</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem;">Architecture approved and first tokens created</p>
          </div>
          <div class="pro-milestone">
            <p class="pro-label">Q2 / Q3</p>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0.25rem 0 0.25rem;">Figma System Live</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem;">Working with complete Git sync</p>
          </div>
          <div class="pro-milestone">
            <p class="pro-label">Q3</p>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0.25rem 0 0.25rem;">Complete Pipeline</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem;">Tokens in production and integrated</p>
          </div>
          <div class="pro-milestone" style="border-bottom: none;">
            <p class="pro-label">Q4</p>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0.25rem 0 0.25rem;">Team Enabled</h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem;">System operational and team trained</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Investment ──────────────────────────────────────────────── -->
    <section id="investimento" class="pro-section-alt">
      <div class="pro-container">
        <div style="margin-bottom: 4rem;">
          <h2 class="pro-h2">Investment</h2>
          <p style="color: var(--color-text-muted); font-size: 1.0625rem; margin-top: 0.75rem;">Structured process starting with Discovery to define precise scope and value</p>
        </div>

        <!-- Discovery card -->
        <div class="pro-card" style="margin-bottom: 3rem; padding: 2.5rem;">
          <p class="pro-label" style="margin-bottom: 0.75rem;">FIRST STEP</p>
          <h3 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem;">Discovery Week</h3>
          <div style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; margin-bottom: 1.25rem;">BRL 3,500</div>
          <p style="color: var(--color-text-muted); font-size: 1rem; line-height: 1.7; max-width: 680px; margin-bottom: 2rem;">
            A week of complete immersion to map your design system's current state, understand specific challenges, co-create the ideal solution and define the detailed project scope.
          </p>

          <div style="border-top: 2px solid var(--color-text); padding-top: 2rem; margin-bottom: 2rem;">
            <h4 style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.25rem;">What happens in Discovery:</h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.875rem;">
              {[
                'Complete audit of the current design system',
                'Mapping of team processes and pain points',
                'Definition of objectives and success metrics',
                'Precise effort and timeline estimation',
                'Final value proposal based on real scope',
                'Detailed implementation roadmap',
              ].map(item => (
                <div style="display:flex; gap:0.625rem; align-items:flex-start;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.5;">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <div style="background: var(--color-text); color: var(--color-bg); padding: 1.75rem; border-radius: var(--radius);">
            <p style="font-weight: 700; font-size: 1rem; margin-bottom: 0.875rem;">After Discovery, you will receive a detailed commercial proposal with:</p>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem;">
              <li style="opacity: 0.9;">· Complete scope customized to your needs</li>
              <li style="opacity: 0.9;">· Total project value based on real complexity</li>
              <li style="opacity: 0.9;">· Detailed timeline with milestones and deliverables</li>
              <li style="opacity: 0.9;">· Contracting model options (Complete or By Phases)</li>
            </ul>
            <p style="font-size: 0.8125rem; opacity: 0.6; margin-top: 1rem;">* Discovery value is deducted from total project if approved</p>
          </div>
        </div>

        <!-- Contracting models -->
        <h3 style="font-size: 1.5rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem;">Contracting Models</h3>
        <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: 2.5rem; line-height: 1.6;">After Discovery, you can choose between two contracting models. The final value will be defined based on the raised scope.</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 3rem;">
          <div>
            <div style="border-bottom: 2px solid var(--color-text); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
              <p class="pro-label" style="margin-bottom: 0.375rem;">Model A</p>
              <h4 style="font-size: 1.5rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.375rem;">Complete Project</h4>
              <p style="color: var(--color-text-muted); font-size: 0.9375rem;">All phases included in final scope</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem;">
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">All deliverables listed in agreed scope</span></div>
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">3 months post-implementation support</span></div>
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">Adjustments and refinements throughout the project</span></div>
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">Satisfaction guarantee</span></div>
            </div>
            <div style="border-top: 1px solid var(--color-border); padding-top: 1rem;">
              <p class="pro-label" style="margin-bottom: 0.375rem;">Payment Method</p>
              <p style="color: var(--color-text-muted); font-size: 0.875rem;">40% on signing · 30% at Phase 2 · 30% on completion</p>
            </div>
          </div>

          <div>
            <div style="border-bottom: 2px solid var(--color-text); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
              <p class="pro-label" style="margin-bottom: 0.375rem;">Model B</p>
              <h4 style="font-size: 1.5rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.375rem;">By Phases</h4>
              <p style="color: var(--color-text-muted); font-size: 0.9375rem;">Phase-by-phase contracting according to scope</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem;">
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">Greater continuity flexibility</span></div>
              <div style="display:flex; gap:0.625rem; align-items:flex-start;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg><span style="font-size:0.9375rem;">Decision to continue after each phase</span></div>
              <div style="display:flex; gap:0.625rem; align-items:flex-start; opacity:0.6;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg><span style="font-size:0.9375rem; color: var(--color-text-muted);">10-15% higher total investment</span></div>
            </div>
            <div style="border-top: 1px solid var(--color-border); padding-top: 1rem;">
              <p class="pro-label" style="margin-bottom: 0.375rem;">Payment Method</p>
              <p style="color: var(--color-text-muted); font-size: 0.875rem;">Payment at the start of each phase</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Results ────────────────────────────────────────────────── -->
    <section id="casos-sucesso" class="pro-section">
      <div class="pro-container">
        <div style="margin-bottom: 4rem;">
          <h2 class="pro-h2">Results</h2>
          <p style="color: var(--color-text-muted); font-size: 1.0625rem; margin-top: 0.75rem;">Success cases and typical results</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0; margin-bottom: 4rem;">
          <div class="pro-metric">
            <div class="pro-metric-value">70%</div>
            <p style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono);">Reduction in creation time</p>
          </div>
          <div class="pro-metric">
            <div class="pro-metric-value">95%</div>
            <p style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono);">Design-code consistency</p>
          </div>
          <div class="pro-metric">
            <div class="pro-metric-value">4-6m</div>
            <p style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono);">ROI through productivity</p>
          </div>
          <div class="pro-metric">
            <div class="pro-metric-value">50%</div>
            <p style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-mono);">Fewer UI bugs</p>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 4rem;">
          <div>
            <h3 style="font-size: 1.25rem; font-weight: 700; text-transform: uppercase; margin-bottom: 1.25rem;">About Poe Bellentani</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
              {[
                'Design System Ops at companies like Zé Delivery and Captalys',
                'Expert in Tokens Studio, Style Dictionary and automations',
                'Speaker at the Figma community on Design Systems',
                'Open-source projects and technical articles on Medium',
                'Frontend developer focused on Design Token implementation',
                'Over 10 years of experience in Design and Development',
              ].map(item => (
                <li style="display:flex; gap:0.75rem; align-items:flex-start; color:var(--color-text-muted); font-size:0.9375rem; line-height:1.5;">
                  <span style="color:var(--color-text); flex-shrink:0; font-weight:700;">·</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 style="font-size: 1.25rem; font-weight: 700; text-transform: uppercase; margin-bottom: 1.25rem;">Technology Stack</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 0.625rem;">
              {['Figma', 'Tokens Studio', 'Style Dictionary', 'GitHub', 'JavaScript', 'React', 'Design Tokens', 'CI/CD'].map(tech => (
                <span style="border: 2px solid var(--color-text); padding: 0.375rem 0.875rem; border-radius: var(--radius-sm); font-size: 0.8125rem; font-weight: 600; font-family: var(--font-mono);">{tech}</span>
